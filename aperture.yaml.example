# Aperture Configuration
# Copy to aperture.yaml and fill in your values.

server:
  host: "0.0.0.0"
  port: 8080

browser:
  pool_size: 5
  chromium_path: "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
  # proxy_url: "http://user:pass@proxy:8080"

llm:
  provider: "openai"
  model: "openai/gpt-4o-mini"         # Use provider/model format for OpenRouter
  # api_key: ""                        # Set via APERTURE_LLM_API_KEY env var
  base_url: "https://openrouter.ai/api" # Remove for direct OpenAI
  max_steps_per_task: 20               # Max steps per task plan (truncated if exceeded)
  max_calls_per_session: 50            # Max LLM API calls per task session

api:
  key_prefix: "apt_"
  require_auth: false                   # Set true for production
  # keys: []                            # Set via APERTURE_API_KEYS env var (comma-separated)
  rate_limit_rpm: 120                   # Requests per minute per IP (0 = unlimited)
  cors_origins: []                      # Allowed origins (empty = allow all)
  cors_reject_unknown: false            # Reject unknown Origin headers (enable in prod)
  max_body_bytes: 1048576               # 1MB request body limit
  max_sessions_per_account: 10          # Max concurrent sessions per billing account
  request_timeout_seconds: 60           # Global request timeout (excludes SSE endpoints)

bridge:
  max_concurrent_tasks: 10
  task_timeout_seconds: 120

checkpoint_ttl_hours: 24                # Max age of checkpoint files before cleanup

stealth:
  enabled: true
  hide_webdriver: true
  canvas_noise: true
  block_webrtc: true
  random_viewport: true
  mock_plugins: true
  timezone: ""                          # e.g., "America/New_York"
  geo_latitude: 0
  geo_longitude: 0

log:
  level: "info"                         # debug, info, warn, error
